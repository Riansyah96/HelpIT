APP_NAME=TechEase_ID
APP_ENV=local
APP_KEY=base64:Pr9U2Ny4CqfHMPZb+dV1GM0dm+OLk8nG9612yUcn3s0=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
APP_TIMEZONE=Asia/Jakarta  # PINDAHKAN ke sini

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ======== DATABASE CONFIGURATION ========
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=techease_db
DB_USERNAME=techease_user
DB_PASSWORD=password123
# ========================================

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_DRIVER=file  # Standar Laravel
CACHE_STORE=file   # Untuk Laravel 9+
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Mail Configuration (Optional)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@techease.id"
MAIL_FROM_NAME="${APP_NAME}"

# ======== TAMBAHAN UNTUK AUTH ========
# Wajib untuk middleware role-based
SESSION_COOKIE=sess_techease
SANCTUM_STATEFUL_DOMAINS=localhost:8000